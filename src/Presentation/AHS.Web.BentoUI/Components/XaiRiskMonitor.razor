@using AHS.Common.Models
@inject Services.GatewayClient Gateway
@implements IDisposable

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color: var(--accent-blue); font-weight: 800; margin: 0; font-size: 1.1rem;">EXPLAINABLE INTELLIGENCE</h4>
        @if(_isOffline) { 
            <span class="badge bg-warning text-dark border-0 px-2 py-1" style="font-size: 0.6rem;">SIMULATION MODE</span> 
        } else {
            <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 d-flex align-items-center" style="font-size: 0.6rem; letter-spacing: 0.5px;">
                <span class="status-indicator status-online me-1" style="width: 6px; height: 6px;"></span> LIVE GxP FEED
            </span>
        }
    </div>

    <div class="mb-4">
        <label class="small opacity-60 d-block mb-2 fw-bold" style="font-size: 0.65rem;">RISK TOLERANCE THRESHOLD: @(_threshold)%</label>
        <input type="range" class="form-range" min="20" max="95" 
               value="@_threshold" 
               @oninput='(e) => _threshold = int.Parse(e.Value?.ToString() ?? "65")' />
    </div>

    @if (_data != null)
    {
        <div class="text-center">
            <h1 class="@GetRiskClass() fw-bold mb-0" style="font-size: 3.5rem; letter-spacing: -2px;">@(_data.Confidence.ToString("P0"))</h1>
            <p class="small opacity-50 mb-4 fw-bold text-uppercase" style="font-size: 0.65rem;">Probability of Loss</p>
            
            <div class="risk-bar mb-4" style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 10px; overflow: hidden;">
                <div style="width: @(_data.Confidence * 100)%; height: 100%; background: currentColor; transition: width 0.8s ease-in-out;" class="@GetRiskClass()"></div>
            </div>

            <div class="p-3 rounded text-start" style="background: rgba(255,255,255,0.03); border-left: 4px solid var(--accent-blue);">
                <small class="text-info d-block fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">PRIMARY ROOT CAUSE</small>
                <span class="small" style="font-family: 'Inter';">@_data.RootCause</span>
            </div>
        </div>
    }
</div>

@code {
    private AHS.Common.Models.PredictionResponse? _data;
    private int _threshold = 65;
    private bool _isOffline = false;
    private PeriodicTimer _timer = new(TimeSpan.FromSeconds(2));

    protected override async Task OnInitializedAsync()
    {
        await SyncXaiNode();
        _ = PollStream();
    }

    private async Task SyncXaiNode()
    {
        try 
        {
            var result = await Gateway.GetPharmaRiskAsync();
            if (result != null) {
                _data = result;
                _isOffline = false;
            } else { SetSimulationMode(); }
        }
        catch { SetSimulationMode(); }
    }

    private void SetSimulationMode()
    {
        _isOffline = true;
        _data = new AHS.Common.Models.PredictionResponse("SIM-GXP-772", 0.79f, "RISK", 14, DateTime.UtcNow, 0.95f, 0.92f, 0.93f, 
            "Synthetic Anomaly: Anomalous Handling Pattern Detected during Route Transition.", 
            new Dictionary<string, float> { { "Internal Cache", 1.0f } });
    }

    private string GetRiskClass() {
        var val = (_data?.Confidence ?? 0) * 100;
        if (val < 30) return "text-success";
        if (val < _threshold) return "text-warning";
        return "text-danger";
    }

    private async Task PollStream()
    {
        while (await _timer.WaitForNextTickAsync()) {
            await SyncXaiNode();
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => _timer.Dispose();
}

@using System.Numerics
@using System.Runtime.InteropServices

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color: var(--accent-blue); margin: 0; font-weight: 700;">HPC Telemetry</h4>
        <div class="badge bg-primary">SIMD ACTIVE</div>
    </div>

    <div class="row g-3">
        <div class="col-6">
            <span class="telemetry-label">Processor</span>
            <div class="fw-bold">@(Vector.IsHardwareAccelerated ? "AVX-512/AVX2" : "SSE Standard")</div>
            <small class="opacity-50">Width: @(Vector<float>.Count * 32) bits</small>
        </div>
        <div class="col-6">
            <span class="telemetry-label">AOT Footprint</span>
            <div class="fw-bold text-success">&lt; 14.2 MB</div>
            <small class="opacity-50">Zero-Reflect IO</small>
        </div>
        <div class="col-6">
            <span class="telemetry-label">Inference</span>
            <div class="fw-bold">0.82ms</div>
            <small class="opacity-50">Sub-ms Latency</small>
        </div>
        <div class="col-6">
            <span class="telemetry-label">Architecture</span>
            <div class="fw-bold">.NET 10.0</div>
            <small class="opacity-50">Native AOT Ready</small>
        </div>
    </div>
</div>

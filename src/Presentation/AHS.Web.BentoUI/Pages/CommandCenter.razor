@page "/"
@page "/command-center"
@using AHS.SaaS.Common.Models
@using global::AHS.SaaS.Engines.HPC
@using AHS.Web.BentoUI.Components
@using System.Diagnostics
@using System.Security.Cryptography
@using System.Text
@implements IDisposable

<div class="dashboard-elite @(_metrics.IsCritical ? "crisis-mode" : "")">
    <Sidebar CriticalCount="@_criticalCount" TransitCount="14" SecureCount="31" IsSystemHealthy="@(!_metrics.IsCritical)" />
    
    <div class="viewport-master">
        <Header>
            <button class="glass-pill dna-btn" @onclick="() => _showDna = true">[ ENGINE_DNA ]</button>
        </Header>
        
        <main class="content-body">
            <div class="bento-v2-grid-refined">
                <!-- ALPHA BOX: CLOCK + FORECAST (ACTIVO) -->
                <div class="bento-item alpha-box">
                    <div class="alpha-content">
                        <JourneyTimeline Metrics="_metrics" />
                        <div class="forecast-separator"></div>
                        <div class="forecast-anchor">
                            <div class="status-indicator-refined">
                                <span class="status-label">SYSTEM_STATE</span>
                                <span class="status-value @(_metrics.IsCritical ? "critical" : "stable")">@(_metrics.IsCritical ? "CRITICAL" : "STABLE")</span>
                            </div>
                            <DeltaTChart Slope="_metrics.Slope" IsCritical="_metrics.IsCritical" />
                        </div>
                    </div>
                </div>

                <div class="bento-item beta-box">
                    <SensorIdentity />
                </div>

                <div class="bento-item gamma-box">
                    <AuditLedger Events="_auditLog" />
                </div>

                <div class="bento-item delta-box">
                    <DataDropZone OnDataParsed="ProcessRealData" />
                </div>
            </div>
        </main>

        <!-- FIXED OVERLAYS -->
        <MitigationActions IsVisible="_metrics.IsCritical" />
        <TelemetryHud LatencyUs="_latencyUs" IsHealthy="@(!_metrics.IsCritical)" />
    </div>
</div>

<XaiDiagnostic IsVisible="_showDna" OnClose="() => _showDna = false" />

<style>
    .dashboard-elite { display: flex; min-height: 100vh; background: #020617; transition: background 1s ease; font-family: 'Inter', sans-serif; overflow: hidden; }
    .crisis-mode { background: radial-gradient(circle at center, #1e0a0a 0%, #020617 100%) !important; }
    
    .viewport-master { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .content-body { flex: 1; padding: 24px 32px; min-width: 0; display: flex; flex-direction: column; overflow-y: auto; }
    
    /* Bento V2.1 Refined Layout */
    .bento-v2-grid-refined {
        display: grid; 
        grid-template-columns: repeat(3, 1fr) 350px;
        grid-template-rows: 350px 1fr; 
        gap: 24px; 
        height: 100%;
        min-height: calc(100vh - 120px);
        grid-template-areas: 
            "alpha alpha alpha gamma"
            "beta delta delta gamma";
    }
    
    .alpha-box { grid-area: alpha; display: flex; align-items: center; padding: 40px; background: rgba(15, 23, 42, 0.4); }
    .beta-box { grid-area: beta; }
    .gamma-box { grid-area: gamma; display: flex; flex-direction: column; }
    .gamma-box .audit-ledger { flex: 1; }
    .delta-box { grid-area: delta; }
    
    .bento-item { background: rgba(15, 23, 42, 0.2); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; transition: all 0.3s ease; overflow: hidden; }
    .bento-item:hover { border-color: rgba(56, 189, 248, 0.3); background: rgba(15, 23, 42, 0.4); }

    /* Alpha Content Specialization */
    .alpha-content { display: grid; grid-template-columns: 1fr 2px 1.5fr; gap: 60px; align-items: center; width: 100%; height: 100%; }
    .forecast-separator { width: 2px; height: 150px; background: linear-gradient(to bottom, transparent, rgba(56, 189, 248, 0.2), transparent); }
    .forecast-anchor { display: flex; flex-direction: column; height: 100%; justify-content: center; gap: 20px; }
    
    .status-indicator-refined { display: flex; flex-direction: column; gap: 4px; }
    .status-label { font-size: 0.6rem; letter-spacing: 2px; color: #64748b; font-weight: 800; }
    .status-value { font-family: 'JetBrains Mono'; font-size: 1.5rem; font-weight: 800; }
    .status-value.stable { color: #38bdf8; text-shadow: 0 0 10px rgba(56, 189, 248, 0.3); }
    .status-value.critical { color: #ef4444; text-shadow: 0 0 10px rgba(239, 68, 68, 0.3); }

    .dna-btn { padding: 4px 12px; border: 1px solid rgba(56, 189, 248, 0.4); background: rgba(56, 189, 248, 0.1); color: #38bdf8; 
               font-family: 'JetBrains Mono'; font-size: 0.65rem; border-radius: 99px; cursor: pointer; transition: all 0.2s; margin-left: 20px; }
    .dna-btn:hover { background: rgba(56, 189, 248, 0.2); border-color: #38bdf8; transform: scale(1.05); }

    .glass-pill { backdrop-filter: blur(10px); }
</style>

@code {
    private bool _showDna = false;
    private bool _isOffline = false;
    private PredictiveShieldMetrics _metrics = new(0, 0, 0, 999, false);
    private List<AuditEvent> _auditLog = new();
    private int _criticalCount = 0;
    private System.Timers.Timer? _timer;
    private List<float> _buffer = new();
    private Random _r = new();
    private int _tick = 0;
    private bool _isUsingRealData = false;
    private double _latencyUs = 0;
    private Stopwatch _sw = new();

    private static readonly string[] EventNames = {
        "TEMP_EXCURSION_DETECTED", "DELTA_T_THRESHOLD_BREACH", "SENSOR_CALIBRATION_OK",
        "COLD_CHAIN_INTEGRITY_CHECK", "UNIT_TRANSFER_INITIATED", "BATCH_SEAL_VERIFIED"
    };
    private static readonly string[] Actions = {
        "ALERT ESCALATED → Fleet Manager", "COOLING UNIT ACTIVATED", "LOG ENTRY CONFIRMED",
        "AUDIT TRAIL UPDATED", "SUPERVISOR NOTIFIED", "GxP COMPLIANCE LOGGED"
    };

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            // Intentar conexión inicial o validación de API aquí si fuera necesario
            StartSimulation();
            await Task.CompletedTask;
        }
        catch (Exception ex)
        {
            _isOffline = true;
            await AddAuditEntry(0.1f, overrideName: "SYSTEM_OFFLINE", overrideAction: "API connection failed. Local simulation enabled.");
            StartSimulation(); // Fallback to local simulation
        }
    }

    private void StartSimulation()
    {
        _timer?.Dispose();
        _timer = new System.Timers.Timer(2000);
        _timer.Elapsed += async (s, e) =>
        {
            if (_isUsingRealData) return;

            _sw.Restart();
            
            float val = 0.8f + (float)_r.NextDouble() * 1.5f;
            _buffer.Add(val);
            if (_buffer.Count > 15) _buffer.RemoveAt(0);
            
            // HPC Injection
            _metrics = ThermalAnalyticsEngine.CalculateTimeToFailure(_buffer.ToArray(), val);

            _tick++;
            if (_tick % 3 == 0)
                await AddAuditEntry(val);

            _sw.Stop();
            _latencyUs = _sw.Elapsed.TotalMilliseconds * 1000.0;

            await InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    private async Task ProcessRealData(float[] data)
    {
        _sw.Restart();
        _isUsingRealData = true;
        _buffer = data.TakeLast(50).ToList();

        _metrics = ThermalAnalyticsEngine.CalculateTimeToFailure(
            _buffer.ToArray().AsSpan(),
            _buffer[^1]
        );

        await AddAuditEntry(_buffer[^1], overrideName: "REAL_DATA_INGESTED", overrideAction: $"CSV LOADED — {data.Length} pts processed by HPC");
        
        _sw.Stop();
        _latencyUs = _sw.Elapsed.TotalMilliseconds * 1000.0;
        
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddAuditEntry(float deltaT, string? overrideName = null, string? overrideAction = null)
    {
        var severity = deltaT >= 1.8f ? EventSeverity.Critical : (deltaT >= 1.4f ? EventSeverity.Warning : EventSeverity.Info);
        if (severity == EventSeverity.Critical) _criticalCount++;
        
        // GxP SHA256 Logic
        string signature;
        using (var sha = SHA256.Create()) {
            var raw = $"{DateTime.UtcNow.Ticks}-{deltaT}-{overrideName}-{_auditLog.Count}";
            var hash = sha.ComputeHash(Encoding.UTF8.GetBytes(raw));
            signature = Convert.ToHexString(hash);
        }

        var ev = new AuditEvent(
            DateTime.UtcNow,
            overrideName ?? EventNames[_r.Next(EventNames.Length)],
            overrideAction ?? Actions[_r.Next(Actions.Length)],
            signature,
            severity
        );
        _auditLog.Insert(0, ev);
        if (_auditLog.Count > 50) _auditLog.RemoveAt(_auditLog.Count - 1);
        await Task.CompletedTask;
    }

    public void Dispose() => _timer?.Dispose();
}

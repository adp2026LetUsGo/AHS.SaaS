@if (IsVisible)
{
    <div class="fixed bottom-[2rem] right-[2rem] z-[100] animate-bounce-in">
        <div class="bg-red-950/90 border border-red-500/50 backdrop-blur-xl p-[1.5rem] rounded-[1rem] shadow-[0_0_2rem_rgba(239,68,68,0.4)] flex items-center gap-[1.5rem]">
            <div class="w-[3rem] h-[3rem] rounded-full bg-red-500 flex items-center justify-center animate-pulse">
                <span class="material-symbols-outlined text-white text-[1.5rem]">emergency_home</span>
            </div>
            <div class="flex flex-col">
                <span class="text-white font-black text-[1.125rem]">MITIGATION_ACTIVE</span>
                <span class="text-red-400 text-[0.75rem] font-mono">COOLING_UNIT_OVERRIDE_INITIATED</span>
            </div>
            <button class="bg-white text-red-900 px-[1rem] py-[0.5rem] rounded-[0.5rem] font-bold text-[0.875rem] hover:bg-red-100 transition-colors">
                ACKNOWLEDGE
            </button>
        </div>
    </div>
}

<style>
    .animate-bounce-in {
        animation: bounce-in 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    @@keyframes bounce-in {
        0% { transform: scale(0.5); opacity: 0; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
}

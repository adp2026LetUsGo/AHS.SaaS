
@using AHS.Common.Domain

@inject Services.GatewayClient Gateway

@implements IDisposable

<div class="glass-card">

    <h3 style="color: var(--accent-blue);
">
Pharma Risk Monitor</h3>
    
@if (_data != null) {
        <p>
Status: <strong>
@_data.Label</strong>
</p>
        <p>
Confidence: @(_data.Confidence.ToString("P"))</p>
        <p>
Latency: @_data.LatencyMs ms</p>
    
} else {
        <p>
Syncing AI Node...</p>
    
}
</div>



@code {

    private AHS.Common.Domain.PredictionResponse? _data;
    private PeriodicTimer _timer = new(TimeSpan.FromSeconds(2));
    protected override void OnInitialized() =>
 _ = PollAsync();
    private async Task PollAsync() {
        while (await _timer.WaitForNextTickAsync()) {
            _data = await Gateway.GetPharmaRiskAsync();
            await InvokeAsync(StateHasChanged);
        
}    
}    public void Dispose() =>
 _timer.Dispose();

}


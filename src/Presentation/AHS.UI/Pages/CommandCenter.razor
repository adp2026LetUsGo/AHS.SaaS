@page "/command-center"
@using AHS.SaaS.Common.Models
@using AHS.SaaS.Engines.HPC
@using AHS.UI.Components
@implements IDisposable

<div class="dashboard-wrapper @(_metrics.IsCritical ? "crisis-active" : "")">
    <Sidebar CriticalCount="@_criticalCount" TransitCount="14" SecureCount="31" IsSystemHealthy="@(!_metrics.IsCritical)" />
    
    <div class="content-wrapper">
        <Header />
        
        <main class="main-content">
            <div class="bento-grid-v2">
                <!-- SENSOR IDENTITY -->
                <div class="area-identity bento-grid-item">
                    <SensorIdentity />
                </div>

                <!-- ALPHA BOX (Doom Clock + Forecast Chart) -->
                <div class="area-alpha bento-grid-item @(_alphaHover ? "alpha-glow" : "")">
                    <div class="alpha-doom" @onmouseover="() => _alphaHover = true" @onmouseout="() => _alphaHover = false">
                        <JourneyTimeline Metrics="_metrics" />
                    </div>
                    <div class="alpha-chart">
                        <div class="chart-header">
                            <span class="section-title">THERMAL PROJECTION (T+30min)</span>
                            @if (_isUsingRealData)
                            {
                                <span class="mode-badge real-data">&#9679; REAL DATA (@_buffer.Count pts)</span>
                            }
                            else
                            {
                                <span class="mode-badge simulated">&#8635; SIMULATED</span>
                            }
                        </div>
                        <div class="chart-wrapper" @onmouseover="() => _alphaHover = true" @onmouseout="() => _alphaHover = false">
                            <DeltaTChart Slope="_metrics.Slope" IsCritical="_metrics.IsCritical" />
                        </div>
                    </div>
                </div>

                <!-- GxP AUDIT LEDGER -->
                <div class="area-audit">
                    <AuditLedger Events="_auditLog" />
                </div>

                <!-- DATA DROP ZONE -->
                <div class="area-drop bento-grid-item">
                    <DataDropZone OnDataParsed="HandleRealDataLoaded" />
                </div>
            </div>
        </main>
        
        <!-- FIXED OVERLAYS -->
        <MitigationActions IsVisible="_metrics.IsCritical" />
        <TelemetryHud />
    </div>
</div>


<style>
    .dashboard-wrapper { display: flex; min-height: 100vh; background: #020617; transition: background 1s ease; font-family: 'Inter', sans-serif; }
    .crisis-active { background: radial-gradient(circle at center, #1e0a0a 0%, #020617 100%) !important; }
    
    .content-wrapper { flex: 1; display: flex; flex-direction: column; position: relative; min-width: 0; }
    .main-content { flex: 1; padding: 24px 32px; min-width: 0; display: flex; flex-direction: column; overflow-y: auto; }
    
    /* Bento V2 4-Column Layout */
    .bento-grid-v2 { 
        display: grid; 
        grid-template-columns: 280px minmax(300px, 1fr) minmax(300px, 1fr) 350px; 
        grid-template-rows: auto 1fr; 
        gap: 24px; 
        height: 100%;
        min-height: calc(100vh - 120px);
        grid-template-areas: 
            "identity alpha alpha audit"
            "drop alpha alpha audit"; 
    }
    
    .area-identity { grid-area: identity; }
    .area-drop { grid-area: drop; }
    .area-audit { grid-area: audit; display: flex; flex-direction: column; }
    .area-audit .audit-ledger { flex: 1; }
    
    /* Alpha Box Integration */
    .area-alpha { 
        grid-area: alpha; 
        display: flex; 
        flex-direction: column; 
        gap: 24px; 
        background: rgba(15,23,42,0.3); 
        border-radius: 20px; 
        padding: 24px; 
        border: 1px solid rgba(255,255,255,0.05); 
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .alpha-glow { 
        box-shadow: inset 0 0 60px rgba(56,189,248,0.05), 0 0 30px rgba(56,189,248,0.1) !important; 
        border-color: rgba(56,189,248,0.3) !important; 
        background: rgba(15,23,42,0.5); 
        transform: translateY(-2px);
    }
    .alpha-doom { flex-shrink: 0; transition: all 0.3s ease; }
    .alpha-glow .alpha-doom { transform: scale(1.02); filter: brightness(1.1); }
    .alpha-chart { flex: 1; display: flex; flex-direction: column; gap: 16px; min-height: 0; justify-content: center; }
    
    .chart-header { display: flex; align-items: center; justify-content: space-between; }
    .section-title { font-size: 0.65rem; letter-spacing: 2px; color: #94a3b8; font-weight: 800; font-family: 'JetBrains Mono', monospace; }
    .mode-badge { font-size: 0.6rem; letter-spacing: 1px; font-weight: 700; padding: 3px 8px; border-radius: 20px; font-family: 'JetBrains Mono', monospace; }
    .mode-badge.real-data { background: rgba(16,185,129,0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
    .mode-badge.simulated { background: rgba(56,189,248,0.1); color: #38bdf8; border: 1px solid rgba(56,189,248,0.2); }
</style>

@code {
    private PredictiveShieldMetrics _metrics = new(0, 0, 0, 999, false);
    private List<AuditEvent> _auditLog = new();
    private int _criticalCount = 0;
    private System.Timers.Timer? _timer;
    private List<float> _buffer = new();
    private Random _r = new();
    private int _tick = 0;
    private bool _isUsingRealData = false;
    private bool _alphaHover = false;

    private static readonly string[] EventNames = {
        "TEMP_EXCURSION_DETECTED", "DELTA_T_THRESHOLD_BREACH", "SENSOR_CALIBRATION_OK",
        "COLD_CHAIN_INTEGRITY_CHECK", "UNIT_TRANSFER_INITIATED", "BATCH_SEAL_VERIFIED"
    };
    private static readonly string[] Actions = {
        "ALERT ESCALATED → Fleet Manager", "COOLING UNIT ACTIVATED", "LOG ENTRY CONFIRMED",
        "AUDIT TRAIL UPDATED", "SUPERVISOR NOTIFIED", "GxP COMPLIANCE LOGGED"
    };

    protected override void OnInitialized()
    {
        StartSimulation();
    }

    private void StartSimulation()
    {
        _timer?.Dispose();
        _timer = new System.Timers.Timer(2000);
        _timer.Elapsed += async (s, e) =>
        {
            if (_isUsingRealData) return;

            float val = 0.8f + (float)_r.NextDouble() * 1.5f;
            _buffer.Add(val);
            if (_buffer.Count > 15) _buffer.RemoveAt(0);
            _metrics = ThermalAnalyticsEngine.CalculateTimeToFailure(_buffer.ToArray(), val);

            _tick++;
            if (_tick % 3 == 0)
                await AddAuditEntry(val);

            await InvokeAsync(StateHasChanged);
        };
        _timer.Start();
    }

    private async Task HandleRealDataLoaded(float[] data)
    {
        _isUsingRealData = true;
        _buffer = data.TakeLast(50).ToList();

        _metrics = ThermalAnalyticsEngine.CalculateTimeToFailure(
            _buffer.ToArray().AsSpan(),
            _buffer[^1]
        );

        await AddAuditEntry(_buffer[^1], overrideName: "REAL_DATA_INGESTED", overrideAction: $"CSV LOADED — {data.Length} pts processed by HPC");
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddAuditEntry(float deltaT, string? overrideName = null, string? overrideAction = null)
    {
        var severity = deltaT >= 1.8f ? EventSeverity.Critical : (deltaT >= 1.4f ? EventSeverity.Warning : EventSeverity.Info);
        if (severity == EventSeverity.Critical) _criticalCount++;
        var sig = $"SHA256:{Guid.NewGuid().ToString("N")[..32]}";
        var ev = new AuditEvent(
            DateTime.UtcNow,
            overrideName ?? EventNames[_r.Next(EventNames.Length)],
            overrideAction ?? Actions[_r.Next(Actions.Length)],
            sig,
            severity
        );
        _auditLog.Insert(0, ev);
        if (_auditLog.Count > 50) _auditLog.RemoveAt(_auditLog.Count - 1);
        await Task.CompletedTask;
    }

    public void Dispose() => _timer?.Dispose();
}

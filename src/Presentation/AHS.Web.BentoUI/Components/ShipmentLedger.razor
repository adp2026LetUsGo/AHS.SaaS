<div class="glass-ledger mt-5">
    <div class="ledger-header ledger-grid">
        <span>Shipment / Batch</span>
        <span>Route Segment</span>
        <span>Condition</span>
        <span class="text-end">GxP Status</span>
    </div>

    @foreach (var s in _shipments)
    {
        <div class="ledger-row ledger-grid">
            <div>
                <strong class="text-white">@s.Id</strong><br />
                <small class="opacity-50">@s.Batch</small>
            </div>
            <div class="small opacity-75">@s.Route</div>
            <div>
                <span class="badge @(s.Temp > 5.0 ? "bg-danger" : "bg-success")" style="font-size: 0.7rem;">
                    @s.Temp.ToString("F1") °C
                </span>
            </div>
            <div class="text-end">
                <span class="fw-bold" style="color: @(s.Status == "VALID" ? "#10b981" : "var(--accent-blue)"); font-size: 0.75rem;">
                    ● @s.Status
                </span>
            </div>
        </div>
    }
</div>

@code {
    private record Shipment(string Id, string Batch, string Route, double Temp, string Status);
    private List<Shipment> _shipments = new()
    {
        new Shipment("GXP-L-9901", "B-992", "PTY -> DAV (Road)", 4.2, "VALID"),
        new Shipment("GXP-L-9902", "B-992", "DAV -> PTY (Road)", 6.1, "EXCURSION"),
        new Shipment("GXP-L-9903", "B-102", "MIA -> PTY (Air)", 3.8, "VALID"),
        new Shipment("GXP-L-9904", "B-105", "PTY -> COL (Sea)", 4.5, "VALID")
    };
}

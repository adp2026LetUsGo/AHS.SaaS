@using AHS.Common.Models
@inject Services.GatewayClient Gateway
@implements IDisposable

<div class="glass-card text-center">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 style="color: var(--accent-blue); margin: 0;">Predictive Risk</h4>
        <button class="btn btn-sm btn-outline-info" @onclick='() => _showDna = true'>Engine DNA</button>
    </div>
    <h1 style="font-size: 5rem; font-weight: 900; color: white; filter: drop-shadow(0 0 15px var(--accent-blue));">84%</h1>
    <span class="badge bg-danger mt-2">CRITICAL ANOMALY</span>
</div>

@if (_showDna) {
    <div class="modal d-block" style="background: rgba(0,0,0,0.9); z-index: 2000; backdrop-filter: blur(10px);">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content" style="background: #0f172a; border-radius: 2rem; color: white; border: 1px solid rgba(255,255,255,0.1);">
                <div class="modal-header border-0 p-4">
                    <h4 class="text-info fw-bold">Model Engineering DNA</h4>
                    <button class="btn-close btn-close-white" @onclick='() => _showDna = false'></button>
                </div>
                <div class="modal-body p-4"><div class="row g-5">
                    <div class="col-md-6 border-end border-secondary">
                        <h6 class="text-white fw-bold mb-3">ENGINEERING</h6>
                        <ul class="list-unstyled small opacity-75">
                            <li>🔹 Algorithm: FastTree MART</li>
                            <li>🔹 Balancing: SMOTE Oversampling</li>
                            <li>🔹 Features: Temporal Lags (T-1)</li>
                            <li>🔹 Serialization: ONNX Opset 21</li>
                            <li>🔹 Logic: .NET 10 Native AOT</li>
                            <li>🔹 Pattern: Result Pattern / Source Gen</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <h6 class="text-white fw-bold mb-3">BUSINESS VALIDATION</h6>
                        <div class="d-flex justify-content-between mb-4">
                            <div><small>RECALL</small><br/><strong class="text-success">95%</strong></div>
                            <div><small>F1-SCORE</small><br/><strong>93%</strong></div>
                        </div>
                        <table class="table table-dark table-sm small opacity-50">
                            <tr><td>False Negative</td><td class="text-danger">MAX LOSS (CAPEX)</td></tr>
                            <tr><td>False Positive</td><td class="text-warning">MIN COST (OPEX)</td></tr>
                        </table>
                    </div>
                </div></div>
                <button class="btn btn-primary w-100 p-4" @onclick='() => _showDna = false'>Close Methodology</button>
            </div>
        </div>
    </div>
}

@code {
    private bool _showDna = false; private PredictionResponse? _data;
    protected override async Task OnInitializedAsync() { try { _data = await Gateway.GetPharmaRiskAsync(); } catch {} }
    public void Dispose() {}
}

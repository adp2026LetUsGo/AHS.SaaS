
<div class="glass-card mt-4" style="min-height: auto;
">

    
<div class="ledger-header ledger-grid mb-3" style="color: var(--accent-blue);
 font-weight: 800;
 font-size: 0.7rem;
 text-transform: uppercase;
">

        <span>
Shipment / Batch</span>
        <span>
Route Segment</span>
        <span>
Temp</span>
        <span class="text-end">
Status</span>
    
</div>

    
@foreach(var s in _shipments) {
        
<div class="ledger-row ledger-grid py-3 border-top border-secondary border-opacity-25">

            
<div>

<strong class="text-white">
@s.Id</strong>
<br/>
<small class="opacity-50">
@s.Batch</small>

</div>

            
<div class="small">

@s.Route
</div>

            
<div>

<span class="badge @(s.Temp >
 5 ? "bg-danger" : "bg-success")">
@s.Temp°C</span>

</div>

            
<div class="text-end fw-bold" style="color: #10b981;
">

● @s.Status
</div>

        
</div>

    
}
</div>



@code {

    private record S(string Id, string Batch, string Route, float Temp, string Status);
    private List<S>
 _shipments = new() {
        new S("GXP-L-9901", "B-992", "PTY -> DAV (Road)", 4.2f, "VALID"),        new S("GXP-L-9902", "B-102", "MIA -> PTY (Air)", 3.8f, "VALID")    
};

}

@using Microsoft.AspNetCore.Components.Forms
@using AHS.UI.Services

<div class="drop-zone @(_isDragging ? "dragging" : "")">
    <InputFile OnChange="HandleFileSelected" @ondragenter="() => _isDragging = true" @ondragleave="() => _isDragging = false" />
    <div class="drop-content">
        <div class="drop-icon">&#8679;</div>
        <p>DROP GxP THERMAL LOGS</p>
        <span>Format: CSV (DeltaT per line)</span>
        @if (_isLoading)
        {
            <div class="loading-bar"><div class="loading-fill"></div></div>
        }
        @if (!string.IsNullOrEmpty(_statusMsg))
        {
            <div class="status-msg @_statusClass">@_statusMsg</div>
        }
    </div>
</div>

<style>
    .drop-zone { position: relative; height: 130px; border: 2px dashed rgba(56,189,248,0.3); border-radius: 16px; background: rgba(15,23,42,0.4); backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; overflow: hidden; }
    .drop-zone.dragging { border-color: #38bdf8; background: rgba(56,189,248,0.1); transform: scale(1.02); box-shadow: 0 0 20px rgba(56,189,248,0.2); }
    .drop-zone :global(input) { position: absolute; width: 100%; height: 100%; opacity: 0; cursor: pointer; }
    .drop-content { text-align: center; pointer-events: none; color: #fff; padding: 0 12px; }
    .drop-icon { font-size: 2rem; color: #38bdf8; line-height: 1; margin-bottom: 4px; }
    .drop-content p { margin: 4px 0; font-size: 0.75rem; font-weight: 700; letter-spacing: 1.5px; color: #94a3b8; }
    .drop-content span { font-size: 0.6rem; color: #475569; }
    .loading-bar { width: 100%; height: 2px; background: rgba(255,255,255,0.05); border-radius: 1px; margin-top: 8px; overflow: hidden; }
    .loading-fill { height: 100%; background: #38bdf8; animation: load-sweep 1s linear infinite; }
    @keyframes load-sweep { 0% { width: 0%; margin-left: 0; } 50% { width: 60%; margin-left: 20%; } 100% { width: 0%; margin-left: 100%; } }
    .status-msg { margin-top: 6px; font-size: 0.65rem; font-weight: 700; letter-spacing: 1px; }
    .status-ok { color: #10b981; }
    .status-err { color: #ef4444; }
</style>

@code {
    [Parameter] public EventCallback<float[]> OnDataParsed { get; set; }
    private bool _isDragging = false;
    private bool _isLoading = false;
    private string _statusMsg = string.Empty;
    private string _statusClass = string.Empty;

    private async Task HandleFileSelected(InputFileChangeEventArgs e) {
        _isDragging = false;
        _isLoading = true;
        _statusMsg = string.Empty;
        StateHasChanged();
        try {
            var data = await ThermalDataParser.ParseThermalLogAsync(e.File);
            _isLoading = false;
            if (data.Length > 0) {
                _statusMsg = $"✓ {data.Length} READINGS LOADED";
                _statusClass = "status-ok";
                await OnDataParsed.InvokeAsync(data);
            } else {
                _statusMsg = "✗ NO VALID DATA FOUND";
                _statusClass = "status-err";
            }
        } catch {
            _isLoading = false;
            _statusMsg = "✗ PARSE ERROR — CHECK FORMAT";
            _statusClass = "status-err";
        }
    }
}

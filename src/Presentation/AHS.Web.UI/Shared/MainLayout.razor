@namespace AHS.Web.UI.Shared

@* ============================================================
   AHS.SaaS — Cold Chain Intelligence Platform
   MainLayout.razor — Master Layout Component
   Blazor Server | Tailwind CSS | AHS Design System v2.0
   ============================================================ *@

@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="scanlines"></div>

<div class="ahs-shell @(IsCollapsed ? "sidebar-collapsed" : "")" id="ahs-shell">

    @* ── SIDEBAR ─────────────────────────────────────────── *@
    <aside class="ahs-sidebar" role="navigation" aria-label="Navegación principal">

        @* Brand Header *@
        <div class="sidebar-brand">
            <div class="brand-mark" title="AHS Cold Chain">AHS</div>
            <div class="brand-text">
                <span class="brand-name">AHS.SAAS</span>
                <span class="brand-sub">Cold Chain Intel</span>
            </div>
            <button class="collapse-btn ms-auto"
                    @onclick="ToggleSidebar"
                    title="@(IsCollapsed ? "Expandir" : "Colapsar") sidebar"
                    aria-expanded="@(!IsCollapsed)">
                @* Chevron icon — invertido al colapsar *@
                <svg xmlns="http://www.w3.org/2000/svg"
                     width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     style="transform: @(IsCollapsed ? "rotate(180deg)" : "rotate(0deg)"); transition: transform 250ms ease;">
                    <polyline points="15 18 9 12 15 6"></polyline>
                </svg>
            </button>
        </div>

        @* Navigation *@
        <nav class="sidebar-nav">

            <span class="nav-section-label">Operaciones</span>

            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"></rect>
                        <rect x="14" y="3" width="7" height="7"></rect>
                        <rect x="14" y="14" width="7" height="7"></rect>
                        <rect x="3" y="14" width="7" height="7"></rect>
                    </svg>
                </span>
                <span class="nav-label">Dashboard</span>
            </NavLink>

            <NavLink class="nav-item" href="/fleet">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <rect x="1" y="3" width="15" height="13"></rect>
                        <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                        <circle cx="5.5" cy="18.5" r="2.5"></circle>
                        <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                </span>
                <span class="nav-label">Fleet Monitor</span>
            </NavLink>

            <NavLink class="nav-item" href="/shipments">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                        <circle cx="12" cy="10" r="3"></circle>
                    </svg>
                </span>
                <span class="nav-label">Shipments</span>
            </NavLink>

            <NavLink class="nav-item" href="/alpha">
                <span class="nav-icon" style="color: var(--color-orange);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                    </svg>
                </span>
                <span class="nav-label" style="color: var(--color-orange-glow);">Alpha Box</span>
            </NavLink>

            <span class="nav-section-label" style="margin-top: 0.5rem;">Inteligencia</span>

            <NavLink class="nav-item" href="/analytics">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="20" x2="18" y2="10"></line>
                        <line x1="12" y1="20" x2="12" y2="4"></line>
                        <line x1="6" y1="20" x2="6" y2="14"></line>
                    </svg>
                </span>
                <span class="nav-label">Analytics</span>
            </NavLink>

            <NavLink class="nav-item" href="/excursions">
                <span class="nav-icon" style="color: var(--color-warn);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path>
                        <line x1="12" y1="9" x2="12" y2="13"></line>
                        <line x1="12" y1="17" x2="12.01" y2="17"></line>
                    </svg>
                </span>
                <span class="nav-label">Excursions</span>
            </NavLink>

            <NavLink class="nav-item" href="/audit">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"></path>
                        <polyline points="14 2 14 8 20 8"></polyline>
                        <line x1="16" y1="13" x2="8" y2="13"></line>
                        <line x1="16" y1="17" x2="8" y2="17"></line>
                        <polyline points="10 9 9 9 8 9"></polyline>
                    </svg>
                </span>
                <span class="nav-label">Audit Ledger</span>
            </NavLink>

            <span class="nav-section-label" style="margin-top: 0.5rem;">Sistema</span>

            <NavLink class="nav-item" href="/config">
                <span class="nav-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                         fill="none" stroke="currentColor" stroke-width="1.75"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3"></circle>
                        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"></path>
                    </svg>
                </span>
                <span class="nav-label">Configuración</span>
            </NavLink>
        </nav>

        @* ── Fleet Pulse (Sparklines) ──────────────────────── *@
        @if (!IsCollapsed)
        {
            <div class="fleet-pulse">
                <div class="fleet-pulse-header">
                    <span class="fleet-pulse-label">Fleet Pulse</span>
                    <span class="fleet-pulse-count">@ActiveUnits / @TotalUnits</span>
                </div>
                <div class="sparkline-row">
                    @foreach (var vehicle in FleetSparklines)
                    {
                        <div class="sparkline-item">
                            <span class="sparkline-vehicle">@vehicle.Id</span>
                            <svg class="sparkline-svg" viewBox="0 0 80 16" preserveAspectRatio="none">
                                <polyline
                                    points="@vehicle.Points"
                                    fill="none"
                                    stroke="@vehicle.Color"
                                    stroke-width="1.5"
                                    stroke-linejoin="round"
                                    stroke-linecap="round"/>
                            </svg>
                        </div>
                    }
                </div>
            </div>
        }
    </aside>

    @* ── TOPBAR ──────────────────────────────────────────── *@
    <header class="ahs-topbar" role="banner">
        @* Breadcrumb *@
        <div class="topbar-breadcrumb">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2"
                 stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5;">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            </svg>
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" style="opacity:0.3;margin:0 0.125rem;">
                <polyline points="9 18 15 12 9 6"></polyline>
            </svg>
            <span class="current">@PageTitle</span>
        </div>

        @* System status strip *@
        <div style="display:flex; align-items:center; gap:1rem; flex:1; justify-content:center;">
            <div style="display:flex; align-items:center; gap:0.375rem;">
                <div class="status-dot ok"></div>
                <span style="font-family:var(--font-mono); font-size:var(--text-2xs); color:var(--color-muted);">
                    SYS NOMINAL
                </span>
            </div>
            <div style="width:1px; height:0.75rem; background:var(--color-border);"></div>
            <span style="font-family:var(--font-mono); font-size:var(--text-2xs); color:var(--color-muted);">
                UNITS: <span style="color:var(--color-ok);">@ActiveUnits</span>/@TotalUnits
            </span>
            <div style="width:1px; height:0.75rem; background:var(--color-border);"></div>
            <span style="font-family:var(--font-mono); font-size:var(--text-2xs); color:var(--color-muted);">
                EXCURSIONS: <span style="color:var(--color-warn);">2</span>
            </span>
        </div>

        @* Actions *@
        <div class="topbar-actions">
            <span class="sys-clock">@SystemTime</span>

            <button class="topbar-btn" title="Notificaciones" aria-label="Notificaciones">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                    <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                </svg>
            </button>

            <div class="user-chip" role="button" tabindex="0" aria-label="Perfil de usuario">
                <div class="user-avatar">OP</div>
                <span>Operador</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.5">
                    <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
            </div>
        </div>
    </header>

    @* ── MAIN CONTENT ────────────────────────────────────── *@
    <main class="ahs-main" role="main" id="ahs-main-content">
        @Body
    </main>

</div>

@* ── CODE-BEHIND ─────────────────────────────────────────── *@
@code {
    // ── State ───────────────────────────────────────────────
    private bool   IsCollapsed { get; set; } = false;
    private string PageTitle   { get; set; } = "Dashboard";
    private string SystemTime  { get; set; } = string.Empty;
    private int    ActiveUnits { get; set; } = 47;
    private int    TotalUnits  { get; set; } = 52;

    private System.Threading.Timer? _clockTimer;

    // ── Fleet Sparkline Data ─────────────────────────────────
    private List<SparklineVehicle> FleetSparklines = new()
    {
        new("V-001", "0,14 10,10 20,12 30,8  40,9  50,11 60,7  70,13 80,10", "#06b6d4"),
        new("V-017", "0,8  10,11 20,9  30,14 40,10 50,8  60,12 70,9  80,11", "#06b6d4"),
        new("V-023", "0,12 10,13 20,15 30,14 40,13 50,14 60,15 70,14 80,15", "#f59e0b"),
        new("V-041", "0,10 10,9  20,11 30,10 40,8  50,10 60,9  70,11 80,9",  "#10b981"),
    };

    // ── Lifecycle ────────────────────────────────────────────
    protected override void OnInitialized()
    {
        UpdateClock();
        _clockTimer = new System.Threading.Timer(
            async _ =>
            {
                UpdateClock();
                await InvokeAsync(StateHasChanged);
            },
            null,
            TimeSpan.FromSeconds(1),
            TimeSpan.FromSeconds(1));
    }

    // ── Methods ──────────────────────────────────────────────
    private void ToggleSidebar() => IsCollapsed = !IsCollapsed;

    private void UpdateClock()
    {
        SystemTime = DateTime.UtcNow.ToString("HH:mm:ss") + " UTC";
    }

    // ── Dispose ──────────────────────────────────────────────
    public void Dispose()
    {
        _clockTimer?.Dispose();
    }

    // ── Inner Models ─────────────────────────────────────────
    private record SparklineVehicle(string Id, string Points, string Color);
}

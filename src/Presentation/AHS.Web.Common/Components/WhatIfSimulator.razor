@using AHS.Common.Models

<div class="ahs-panel simulator-card" style="border-top: 2px solid var(--color-orange, #ea580c);">
    <div class="panel-header mb-4 flex justify-between items-center">
        <h3 class="panel-title">PRE-FLIGHT_RISK_SIMULATOR</h3>
        <span class="panel-badge warn">ORACLE_V2</span>
    </div>
    <div class="flex flex-col gap-4">
        <div class="input-field">
            <label class="text-[10px] text-slate-500">CARRIER_PROTOCOL</label>
            <input @bind="Profile.CarrierName" class="bg-black border border-white/10 p-2 text-white w-full" placeholder="ENTER_ID..." />
        </div>
        
        <div class="input-field">
            <label class="text-[10px] text-slate-500">ROUTE_ID</label>
            <select @bind="Profile.RouteId" class="bg-black border border-white/10 p-2 text-white w-full">
                <option value="ROUTE_PTY_DAV">PTY -> DAVID (CRITICAL)</option>
                <option value="ROUTE_COL_BOG">COL -> BOGOTA (NOMINAL)</option>
                <option value="ROUTE_MX_GDL">MEX -> GDL (ELEVATED)</option>
            </select>
        </div>

        <div class="input-field">
            <label class="text-[10px] text-slate-500">INSULATION_TYPE</label>
            <select @bind="Profile.Insulation" class="bg-black border border-white/10 p-2 text-white w-full">
                <option value="@InsulationType.Passive">PASSIVE_CHAMBER</option>
                <option value="@InsulationType.Active">ACTIVE_REEFER</option>
            </select>
        </div>

        <div class="input-field">
            <label class="text-[10px] text-slate-500">EXTERNAL_TEMP (°C)</label>
            <input type="number" step="0.1" @bind="Profile.ExternalTempForecast" class="bg-black border border-white/10 p-2 text-white w-full" />
        </div>

        <button @onclick="() => OnAnalyze.InvokeAsync(Profile)" class="bg-orange-600 p-3 font-bold text-white hover:bg-orange-500 mt-2">
            INYECTAR_SIMULACIÓN
        </button>
    </div>
</div>

<style>
    .input-field { display: flex; flex-direction: column; gap: 0.25rem; }
</style>

@code {
    [Parameter] public ShipmentRiskProfile Profile { get; set; } = new();
    [Parameter] public EventCallback<ShipmentRiskProfile> OnAnalyze { get; set; }
}

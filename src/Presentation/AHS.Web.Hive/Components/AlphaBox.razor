@namespace AHS.Web.Hive.Components

<div class="ahs-panel alpha-box @(IsCritical ? "critical-alert" : "")" style="position: relative; padding: 1rem; border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; background: rgba(15, 23, 42, 0.4);">
    <div class="doom-ring"></div>
    <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: #64748b; letter-spacing: 1px; display: block; margin-bottom: 0.5rem;">
        ⬡ TIME_TO_FAILURE
    </span>
    <div style="font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 800; color: @(IsCritical ? "#ef4444" : "#38bdf8"); text-shadow: 0 0 15px @(IsCritical ? "rgba(239, 68, 68, 0.3)" : "rgba(56, 189, 248, 0.3)");">
        @formatTime(TtfMinutes)
    </div>
    <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: #94a3b8; margin-top: 0.5rem; text-transform: uppercase;">
        @(IsCritical ? "CRITICAL_ANOMALY_DETECTED" : "SYSTEM_STABLE_NOMINAL")
    </div>
</div>

@code {
    [Parameter] public double TtfMinutes { get; set; }
    [Parameter] public bool IsCritical { get; set; }

    private string formatTime(double minutes)
    {
        int h = (int)(minutes / 60);
        int m = (int)(minutes % 60);
        int s = (int)((minutes * 60) % 60);
        return $"{h:D2}:{m:D2}:{s:D2}";
    }
}

@page "/"
@namespace AHS.Web.Hive.Pages
@using System.Diagnostics
@using AHS.Engines.HPC
@using AHS.Common.Domain
@inject IJSRuntime JSRuntime

<div class="sovereign-console-layout" style="display: flex; flex-direction: column; gap: 1rem; padding: 2rem; background: #020617; min-height: 100vh; width: 100vw; max-width: none !important;">

    @* ── TOP ROW: CABIN SYMMETRY (1:1:1:1) ────────────────── *@
    <div class="top-row-grid" style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 1rem;">
        
        @* 1. DOOM CLOCK / ALPHA BOX *@
        <div class="ahs-panel alpha-box @(_isSimulatedPrediction ? "sim-active" : "")" style="position: relative; padding: 1rem;">
            @if (_isSimulatedPrediction)
            {
                <div class="pre-flight-tag">[ PRE-FLIGHT_PREDICTION ]</div>
            }
            <div class="doom-ring"></div>
            <span class="doom-label">⬡ TIME TO FAILURE</span>
            <div class="doom-clock @(DoomMinutes < 30 ? "critical" : "")">
                @DoomDisplay
            </div>
            <div class="doom-context">@_activeLabel</div>
        </div>

        @* 2. FLEET ACTIVE *@
        <div class="ahs-panel" style="padding: 1rem;">
            <div class="panel-header">
                <span class="panel-title">Fleet Activo</span>
                <div class="status-dot ok"></div>
            </div>
            <div style="display:flex; align-items:baseline; gap:0.375rem; margin-top: 0.5rem;">
                <span class="metric-value">47</span>
                <span class="metric-unit">/ 52</span>
            </div>
            <div style="margin-top:0.75rem;">
                <div class="ahs-progress-track">
                    <div class="ahs-progress-fill" style="width:90.4%;"></div>
                </div>
            </div>
        </div>

        @* 3. LOGISTICS ORACLE *@
        <div class="ahs-panel" style="padding: 1rem;">
            <div class="panel-header">
                <span class="panel-title">Logistics Oracle</span>
                <div class="status-dot @(OracleResult?.RiskLevel == "CRITICAL" ? "alert" : OracleResult?.RiskLevel == "ELEVATED" ? "warn" : "ok")"></div>
            </div>
            <div style="display:flex; align-items:baseline; gap:0.375rem; margin-top: 0.5rem;">
                <span class="metric-value">@OracleResult?.CompositeRiskScore.ToString("F1")%</span>
                <span class="metric-unit">RISK</span>
            </div>
            <div style="margin-top:0.5rem; display:flex; flex-direction:column; gap:0.25rem;">
                <div style="display:flex; justify-content:space-between; font-family:var(--font-mono); font-size:var(--text-2xs);">
                    <span style="color:var(--color-muted);">LEVEL:</span>
                    <span style="color:@(OracleResult?.RiskLevel == "CRITICAL" ? "var(--color-alert)" : "var(--color-warn)"); font-weight:bold;">@OracleResult?.RiskLevel</span>
                </div>
            </div>
        </div>

        @* 4. DATABRIDGE (Compact Ingestion) *@
        <div class="ahs-panel" style="padding: 0.75rem;">
            <div class="panel-header" style="margin-bottom: 0.5rem;">
                <span class="panel-title">DATABRIDGE_INGEST</span>
            </div>
            <DataBridge OnDataIngested="HandleDataIngested" />
        </div>
    </div>

    @* ── BODY ROW: WORKSPACE (3:1) ─────────────────────────── *@
    <div class="body-row-grid" style="display: grid; grid-template-columns: 3fr 1fr; gap: 1rem; flex: 1;">
        
        @* LEFT: MASSIVE GRID (75%) *@
        <div class="grid-workspace">
            <ShipmentRiskGrid Shipments="@_results" 
                              IsProcessing="@_isHpcActive" 
                              Status="@_hpcStatus" 
                              TrainingTime="@_trainingSeconds" 
                              Accuracy="95.2" />
        </div>

        @* RIGHT: MANUAL SIMULATOR (25%) *@
        <div class="simulator-workspace">
            <WhatIfSimulator OnAnalyze="HandleManualInyection" />
        </div>
    </div>

</div>

@if (_showGxpModal)
{
    <div class="gxp-overlay">
        <div class="gxp-modal" style="width: 30rem;">
            <div class="gxp-header">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ec5b13" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                </svg>
                GxP_DATA_DETECTED
            </div>
            <div class="gxp-body">
                <p>Se han identificado [@(_pendingEntries.Count)] registros de telemetría crítica.</p>
                <p class="gxp-query">¿Desea iniciar el entrenamiento del modelo predictivo SIMD?</p>
            </div>
            <div class="gxp-actions">
                <button class="gxp-btn gxp-confirm" @onclick="ConfirmTraining">[ SÍ_ENTRENAR ]</button>
                <button class="gxp-btn gxp-cancel" @onclick="CancelTraining">[ NO_CANCELAR ]</button>
            </div>
        </div>
    </div>
}

@* ── SESSION RECOVERY MODAL ────────────────────────────────── *@
@if (_showRecoveryModal)
{
    <div class="gxp-overlay">
        <div class="gxp-modal" style="width: 30rem; border-color: #06b6d4; box-shadow: 0 0 30px rgba(6, 182, 212, 0.2);">
            <div class="gxp-header" style="color: #06b6d4; border-bottom-color: rgba(6, 182, 212, 0.2);">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2">
                    <path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/>
                </svg>
                REANUDAR_SESIÓN_GxP_ANTERIOR?
            </div>
            <div class="gxp-body">
                <p>Se ha detectado un buffer de telemetría previo en la memoria del navegador.</p>
                <p class="gxp-query">¿Desea restaurar los registros y el estado de la última sesión?</p>
            </div>
            <div class="gxp-actions">
                <button class="gxp-btn" style="background: #06b6d4; color: white;" @onclick="RestoreSession">[ SÍ_REANUDAR ]</button>
                <button class="gxp-btn gxp-cancel" @onclick="ClearSession">[ NO_DESCARTAR ]</button>
            </div>
        </div>
    </div>
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&display=swap');

    .critical { color: var(--color-alert) !important; text-shadow: 0 0 10px var(--color-alert); }
    
    .metric-value, .doom-clock, .temp-value, .doom-context {
        font-family: 'JetBrains Mono', monospace !important;
    }

    .doom-clock {
        font-weight: 800;
        letter-spacing: -1px;
    }

    .metric-value {
        font-weight: 700;
        font-size: 1.5rem;
    }

    .alpha-box.sim-active {
        border: 2px solid #ec5b13 !important;
        animation: pulse-orange 2s infinite;
    }

    @@keyframes pulse-orange {
        0% { box-shadow: 0 0 0 0 rgba(236, 91, 19, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(236, 91, 19, 0); }
        100% { box-shadow: 0 0 0 0 rgba(236, 91, 19, 0); }
    }

    .pre-flight-tag {
        position: absolute;
        top: -0.5rem;
        left: 50%;
        transform: translateX(-50%);
        background: #ec5b13;
        color: white;
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.5rem;
        padding: 0.1rem 0.4rem;
        border-radius: 2px;
        font-weight: 800;
        z-index: 10;
    }

    .gxp-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(2, 6, 23, 0.9);
        display: flex; align-items: center; justify-content: center;
        z-index: 1000; backdrop-filter: blur(4px);
    }
    .gxp-modal {
        background: #020617; border: 1px solid #ec5b13; padding: 2rem;
        border-radius: 4px;
        box-shadow: 0 0 30px rgba(236, 91, 19, 0.2);
    }
    .gxp-header {
        display: flex; align-items: center; gap: 0.75rem; 
        font-family: 'JetBrains Mono', monospace; font-weight: 800; color: #ec5b13;
        margin-bottom: 1.5rem; border-bottom: 1px solid rgba(236, 91, 19, 0.2);
        padding-bottom: 0.75rem;
    }
    .gxp-body { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; line-height: 1.6; color: #94a3b8; }
    .gxp-query { color: #cbd5e1; font-weight: 700; margin-top: 1rem; }
    
    .gxp-actions { display: flex; gap: 1rem; margin-top: 2rem; }
    .gxp-btn {
        flex: 1; padding: 0.75rem; font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem; font-weight: 800; border: none; cursor: pointer;
        transition: all 0.2s ease;
    }
    .gxp-confirm { background: #ec5b13; color: white; }
    .gxp-confirm:hover { background: #f97316; box-shadow: 0 0 15px rgba(236, 91, 19, 0.4); }
    .gxp-cancel { background: #1e293b; color: #94a3b8; }
    .gxp-cancel:hover { background: #334155; }
</style>

@code {
    private int DoomMinutes { get; set; } = 47;
    private float ActiveRiskScore { get; set; } = 0;
    private LogisticsOracleResult? OracleResult;
    private List<ShipmentRiskGrid.ShipmentRiskEntry> _results = new();
    private List<ShipmentRiskGrid.ShipmentRiskEntry> _pendingEntries = new();
    
    private string _activeLabel = "LOGISTICS_ANALYTICS_ACTIVE";
    private bool _showGxpModal = false;
    private bool _showRecoveryModal = false;
    private bool _isSimulatedPrediction = false;
    
    // Telemetry State
    private bool _isHpcActive = false;
    private string _hpcStatus = "IDLE";
    private double _trainingSeconds = 0.00;
    private Stopwatch _stopwatch = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var savedData = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ahs_gxp_session");
            if (!string.IsNullOrEmpty(savedData))
            {
                _showRecoveryModal = true;
                StateHasChanged();
            }
        }
    }

    private async Task RestoreSession()
    {
        var savedData = await JSRuntime.InvokeAsync<string>("sessionStorage.getItem", "ahs_gxp_session");
        if (!string.IsNullOrEmpty(savedData))
        {
            _results = System.Text.Json.JsonSerializer.Deserialize<List<ShipmentRiskGrid.ShipmentRiskEntry>>(savedData) ?? new();
            UpdateGlobalState(skipSave: true);
            _hpcStatus = "SESIÓN_RESTAURADA";
        }
        _showRecoveryModal = false;
        StateHasChanged();
    }

    private async Task ClearSession()
    {
        await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "ahs_gxp_session");
        _showRecoveryModal = false;
        StateHasChanged();
    }

    private async Task SaveSession()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(_results);
        await JSRuntime.InvokeVoidAsync("sessionStorage.setItem", "ahs_gxp_session", json);
    }

    private int PessimisticDoomMinutes => (int)(OracleResult?.PessimisticTTF ?? DoomMinutes);

    private string DoomDisplay =>
        $"{PessimisticDoomMinutes / 60:D2}:{PessimisticDoomMinutes % 60:D2}:{DateTime.Now.Second:D2}";

    private void HandleDataIngested(List<ShipmentRiskGrid.ShipmentRiskEntry> entries)
    {
        _pendingEntries = entries;
        _showGxpModal = true;
        StateHasChanged();
    }

    private async Task ConfirmTraining()
    {
        _showGxpModal = false;
        _isSimulatedPrediction = false; // Reset on real data
        _isHpcActive = true;
        _hpcStatus = "ENTRENANDO_MODELO";
        _stopwatch.Restart();
        
        // Simular latencia de supercomputadora para el efecto visual
        await Task.Delay(1250); 
        
        _stopwatch.Stop();
        _trainingSeconds = _stopwatch.Elapsed.TotalSeconds;
        _results = _pendingEntries;
        _hpcStatus = "INFERENCIA_COMPLETA";
        _isHpcActive = false;
        _activeLabel = OracleResult?.RiskLevel == "CRITICAL" ? "THREAT_FOUND" : "SYSTEM_STABLE";
        
        UpdateGlobalState(); // This will trigger SaveSession
        StateHasChanged();
    }

    private void CancelTraining()
    {
        _showGxpModal = false;
        _pendingEntries.Clear();
        _hpcStatus = "OPERACIÓN_CANCELADA";
        StateHasChanged();
    }

    private void HandleManualInyection(ShipmentRiskProfile profile)
    {
        _isSimulatedPrediction = true;
        
        // Ponderación de amenaza según ruta real (mantenemos lógica del simulador previo)
        float threat = profile.RouteId?.Contains("PTY") == true ? 0.85f : 0.35f;
        float reliability = profile.CarrierName?.Contains("PREMIUM") == true ? 0.98f : 0.85f;
        
        var updatedProfile = profile with { 
            RouteThreatLevel = threat, 
            CarrierReliability = reliability 
        };
        
        var prediction = LogisticsInferenceEngine.PredictLogisticsRisk(updatedProfile, (float)DoomMinutes);
        
        var entry = new ShipmentRiskGrid.ShipmentRiskEntry(
            _results.Count + 1,
            profile.CarrierName ?? "N/A",
            profile.Insulation,
            prediction.CompositeRiskScore,
            prediction.RiskLevel,
            prediction.PrimaryInsight
        );

        _results.Insert(0, entry);
        OracleResult = prediction;
        ActiveRiskScore = prediction.CompositeRiskScore;
        
        _activeLabel = "MANUAL_INJECTION_ACTIVE";
        UpdateGlobalState();
        StateHasChanged();
    }

    private void HandleSimulatorResult(ShipmentRiskGrid.ShipmentRiskEntry entry)
    {
        _isSimulatedPrediction = true;
        // Add as manual override - Protocolo #MANUAL_PREDICT (ID redundant here but handled in Grid)
        var manualEntry = entry; 
        _results.Insert(0, manualEntry);
        UpdateGlobalState();
        _activeLabel = "MANUAL_INJECTION_ACTIVE";
        StateHasChanged();
    }

    private void UpdateGlobalState(bool skipSave = false)
    {
        if (_results.Any())
        {
            var topRisk = _results.MaxBy(e => e.RiskScore);
            if (topRisk != null)
            {
                OracleResult = new LogisticsOracleResult(topRisk.RiskScore, 47f * (1.0f - (topRisk.RiskScore / 200f)), topRisk.Status, topRisk.Insight);
                ActiveRiskScore = topRisk.RiskScore;
            }
        }

        if (!skipSave)
        {
            _ = SaveSession();
        }
    }
}

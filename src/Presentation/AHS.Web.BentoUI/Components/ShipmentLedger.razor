<div class="glass-ledger">
    <div class="ledger-header">
        <span>Shipment ID</span>
        <span>Origin/Destination</span>
        <span>Condition</span>
        <span class="text-end">Status</span>
    </div>

    @foreach (var shipment in _shipments)
    {
        <div class="ledger-row">
            <div>
                <strong style="color: white;">@shipment.Id</strong><br/>
                <small class="opacity-50">Batch: @shipment.Batch</small>
            </div>
            <div class="small">@shipment.Route</div>
            <div class="small">
                <span class="badge @(shipment.TempExcursion ? "bg-danger" : "bg-dark")" style="font-size: 0.6rem;">
                    @(shipment.Temperature)°C
                </span>
            </div>
            <div class="text-end">
                @if (shipment.IsAtRisk)
                {
                    <i class="bi bi-exclamation-triangle-fill text-danger" title="Risk Detected"></i>
                }
                else
                {
                    <i class="bi bi-shield-check text-success" title="Secure"></i>
                }
            </div>
        </div>
    }
</div>

@code {
    private record Shipment(string Id, string Batch, string Route, float Temperature, bool TempExcursion, bool IsAtRisk);
    
    private List<Shipment> _shipments = new()
    {
        new Shipment("GXP-8821", "B-992", "PTY -> DAV", 4.2f, false, false),
        new Shipment("GXP-8822", "B-992", "DAV -> PTY", 6.8f, true, true),
        new Shipment("GXP-8823", "B-995", "PTY -> COL", 3.9f, false, false),
        new Shipment("GXP-8824", "B-998", "MIA -> PTY", 4.5f, false, false),
        new Shipment("GXP-8825", "B-102", "PTY -> GUA", 7.2f, true, true)
    };
}

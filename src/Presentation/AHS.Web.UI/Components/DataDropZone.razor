
@using Microsoft.AspNetCore.Components.Forms

@using AHS.Web.UI.Services

<div class="smart-ingest-container">

    
<div class="ingest-box @(_isDragging ? "dragging" : "")" @ondragenter="() =>

 _isDragging = true" @ondragleave="() =>
 _isDragging = false">
        <InputFile OnChange="HandleFile" class="hidden-input" id="fileIn" />
        <label for="fileIn" class="drop-label">
            <i class="bi bi-cloud-haze2-fill neon-icon">
</i>
            <span>
INGEST_GxP_DATA</span>
            <small>
Drag & Drop or Click to Sync</small>
            
@if (_isLoading)            {
                
<div class="loading-bar">


<div class="loading-fill">


</div>


</div>

            
}            
@if (!string.IsNullOrEmpty(_statusMsg))            {
                
<div class="status-msg @_statusClass">

@_statusMsg
</div>

            
}        </label>
    
</div>


</div>

<style>
    .smart-ingest-container {
 height: 100%;
 display: flex;
 align-items: center;
 width: 100%;
 
}    .ingest-box {
 width: 100%;
 border: 2px dashed rgba(56, 189, 248, 0.2);
 border-radius: 16px;
                   transition: all 0.3s ease;
 background: rgba(15, 23, 42, 0.3);
 position: relative;
 overflow: hidden;
 
}    .ingest-box:hover, .ingest-box.dragging {
 border-color: #38bdf8;
 background: rgba(56, 189, 248, 0.05);
 
}    .hidden-input {
 display: none;
 
}    .drop-label {
 display: flex;
 flex-direction: column;
 align-items: center;
 padding: 30px;
 cursor: pointer;
 width: 100%;
 
}    .neon-icon {
 font-size: 2.5rem;
 color: #38bdf8;
 text-shadow: 0 0 15px rgba(56, 189, 248, 0.5);
 
}    .drop-label span {
 color: white;
 font-weight: 800;
 font-size: 0.8rem;
 margin-top: 10px;
 
}    .drop-label small {
 color: #64748b;
 font-size: 0.6rem;
 
}    .loading-bar {
 width: 100%;
 height: 2px;
 background: rgba(255,255,255,0.05);
 border-radius: 1px;
 margin-top: 8px;
 overflow: hidden;
 
}    .loading-fill {
 height: 100%;
 background: #38bdf8;
 animation: load-sweep 1s linear infinite;
 
}    @@keyframes load-sweep {
 0% {
 width: 0%;
 margin-left: 0;
 
} 50% {
 width: 60%;
 margin-left: 20%;
 
} 100% {
 width: 0%;
 margin-left: 100%;
 
} 
}    .status-msg {
 margin-top: 6px;
 font-size: 0.65rem;
 font-weight: 700;
 letter-spacing: 1px;
 
}    .status-ok {
 color: #10b981;
 
}    .status-err {
 color: #ef4444;
 
}</style>


@code {

    
[Parameter] public EventCallback<float[]>
 OnDataParsed {
 get;
 set;
 
}    private bool _isDragging = false;
    private bool _isLoading = false;
    private string _statusMsg = string.Empty;
    private string _statusClass = string.Empty;
    private async Task HandleFile(InputFileChangeEventArgs e) {
        _isDragging = false;
        _isLoading = true;
        _statusMsg = string.Empty;
        StateHasChanged();
        try {
            var data = await ThermalDataParser.ParseThermalLogAsync(e.File);
            _isLoading = false;
            if (data.Length >
 0) {
                _statusMsg = $"✓ {
data.Length
} READINGS LOADED";
                _statusClass = "status-ok";
                await OnDataParsed.InvokeAsync(data);
            
} else {
                _statusMsg = "✗ NO VALID DATA FOUND";
                _statusClass = "status-err";
            
}        
} catch {
            _isLoading = false;
            _statusMsg = "✗ PARSE ERROR — CHECK FORMAT";
            _statusClass = "status-err";
        
}    
}
}


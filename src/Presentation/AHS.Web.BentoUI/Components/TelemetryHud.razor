<div class="telemetry-hud mono">
    <div class="hud-item @(_pulse ? "tick" : "")">
        <label>SIMD_LATENCY</label> <span>@(LatencyUs.ToString("F2"))µs</span>
    </div>
    <div class="hud-item"><label>GxP_INTEGRITY</label> <span class="@(IsHealthy ? "healthy" : "warning")">@(IsHealthy ? "SECURED" : "RECONSTRUCTING")</span></div>
</div>

<style>
    .telemetry-hud { position: fixed; bottom: 25px; left: 320px; display: flex; gap: 35px; padding: 12px 25px; background: rgba(2, 6, 23, 0.5); border-radius: 10px; font-family: 'JetBrains Mono'; font-size: 0.6rem; pointer-events: none; border: 1px solid rgba(255,255,255,0.05); z-index: 1000; }
    .hud-item label { color: #475569; margin-right: 8px; }
    .hud-item span { color: #38bdf8; font-weight: 800; }
    .hud-item span.healthy { color: #10b981; }
    .hud-item span.warning { color: #ef4444; }
    .hud-item.tick span { color: #fff; text-shadow: 0 0 10px #38bdf8; transition: all 0.1s; }
</style>

@code {
    [Parameter] public double LatencyUs { get; set; } = 420;
    [Parameter] public bool IsHealthy { get; set; } = true;

    private bool _pulse;
    protected override void OnParametersSet() => _pulse = !_pulse;
}

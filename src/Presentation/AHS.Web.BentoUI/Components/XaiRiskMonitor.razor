@using AHS.Common.Models
@inject Services.GatewayClient Gateway
@implements IDisposable

<div class="glass-card">
    <div>
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 style="color: var(--accent-blue); margin: 0; font-weight: 700; letter-spacing: -0.5px;">Predictive Risk</h4>
            <button class="btn btn-sm btn-outline-info px-3 py-1 fw-bold" style="font-size: 0.65rem; border-radius: 8px;" @onclick="() => _showDna = true">ENGINE DNA</button>
        </div>

        <div class="text-center mt-5">
            <h1 class="risk-display">@(_data?.Confidence.ToString("P0") ?? "--%")</h1>
            <div class="methodology-summary">
                FastTree Engine | SMOTE Balanced | 95% Recall
            </div>
        </div>
    </div>

    <div class="mt-4">
        <label class="small opacity-50 mb-2 d-block text-uppercase fw-bold" style="font-size: 0.6rem; letter-spacing: 1.5px;">Risk Sensitivity Threshold</label>
        <input type="range" class="form-range" min="30" max="95" value="65" />
    </div>
</div>

@if (_showDna)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.85); z-index: 2000; backdrop-filter: blur(12px);">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content modal-glass p-4 border-0">
                <div class="modal-header border-0 p-4">
                    <h3 class="modal-title fw-bold text-info">Model Methodology DNA</h3>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => _showDna = false"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row g-5">
                        <div class="col-md-6 border-end border-secondary">
                            <h5 class="text-white mb-4 fw-bold">Engineering Stack</h5>
                            <ul class="list-unstyled">
                                <li class="mb-3">🔹 Algorithm: <strong>FastTree MART (Gradient Boosting)</strong></li>
                                <li class="mb-3">🔹 Balancing: <strong>SMOTE (Synthetic Minority)</strong></li>
                                <li class="mb-3">🔹 Features: <strong>Temporal Lags (T-1 analytics)</strong></li>
                                <li class="mb-3">🔹 Format: <strong>ONNX Opset 21 Serialization</strong></li>
                                <li class="mb-3">🔹 Runtime: <strong>.NET 10 Native AOT Ready</strong></li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-white mb-4 fw-bold">Financial Matrix Focus</h5>
                            <table class="table table-dark table-sm small opacity-75 mt-3">
                                <thead class="text-info">
                                    <tr><th>Matrix State</th><th>Business Impact</th><th>Cost focus</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>True Positive</td><td>Intervention Success</td><td>OPEX Savings</td></tr>
                                    <tr><td>False Negative</td><td class="text-danger">Product Loss</td><td>MAX LOSS</td></tr>
                                    <tr><td>False Positive</td><td class="text-warning">Preventive Check</td><td>MIN COST (2%)</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-4">
                    <button class="btn btn-primary w-100 p-3 fw-bold" style="border-radius: 12px;" @onclick="() => _showDna = false">Return to Dashboard</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PredictionResponse? _data;
    private bool _showDna = false;
    private PeriodicTimer _timer = new(TimeSpan.FromSeconds(3));

    protected override async Task OnInitializedAsync()
    {
        await Fetch();
        _ = Poll();
    }

    private async Task Fetch()
    {
        try {
            _data = await Gateway.GetPharmaRiskAsync();
        } catch { }
    }

    private async Task Poll()
    {
        while (await _timer.WaitForNextTickAsync())
        {
            await Fetch();
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => _timer.Dispose();
}

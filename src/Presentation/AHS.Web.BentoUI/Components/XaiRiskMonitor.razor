@using AHS.Common.Models
@inject Services.GatewayClient Gateway
@implements IDisposable

<div class="glass-card p-4 h-100">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 style="color: var(--accent-blue); font-weight: 800; margin: 0;">PREDICTIVE RISK</h4>
        @if(!_isOffline) { <span class="badge bg-success-subtle text-success border border-success px-2 py-1" style="font-size: 0.6rem;">LIVE GxP FEED</span> }
    </div>

    @if (_data != null)
    {
        <div class="text-center">
            <h1 class="fw-bold mb-0 @GetRiskClass()" style="font-size: 3rem; letter-spacing: -2px;">@(_data.Confidence.ToString("P0"))</h1>
            
            <!-- RISK SPARKLINE VISUAL -->
            <div class="sparkline-container">
                <svg viewBox="0 0 100 25" preserveAspectRatio="none" style="width: 100%; height: 100%;">
                    <path class="sparkline-path" d="@_sparklinePath" />
                </svg>
                <div class="d-flex justify-content-between opacity-25 mt-1" style="font-size: 0.5rem;">
                    <span>T-5h</span><span>LIVE</span>
                </div>
            </div>

            <div class="mt-4 p-3 rounded text-start" style="background: rgba(255,255,255,0.03); border-left: 3px solid var(--accent-blue);">
                <small class="text-info d-block fw-bold mb-1" style="font-size: 0.65rem;">ROOT CAUSE</small>
                <span class="small" style="font-family: 'Inter';">@_data.RootCause</span>
            </div>
        </div>
    }
</div>

@code {
    private PredictionResponse? _data;
    private bool _isOffline = false;
    private string _sparklinePath = "M 0 20 L 20 15 L 40 22 L 60 10 L 80 18 L 100 12"; // Mock trajectory
    private PeriodicTimer _timer = new(TimeSpan.FromSeconds(3));

    protected override async Task OnInitializedAsync() {
        await Fetch();
        _ = Poll();
    }

    private async Task Fetch() {
        try {
            var r = await Gateway.GetPharmaRiskAsync();
            if (r != null) { _data = r; _isOffline = false; UpdateSparkline(); }
            else { SetOffline(); }
        } catch { SetOffline(); }
    }

    private void UpdateSparkline() {
        // Randomize sparkline slightly to simulate real-time movement
        var rand = new Random();
        _sparklinePath = $"M 0 {rand.Next(15,25)} L 20 {rand.Next(10,20)} L 40 {rand.Next(15,25)} L 60 {rand.Next(5,15)} L 80 {rand.Next(10,20)} L 100 {rand.Next(10,15)}";
    }

    private void SetOffline() {
        _isOffline = true;
        _data = new PredictionResponse("OFF-01", 0.76f, "STABLE", 12, DateTime.UtcNow, 0.95f, 0.92f, 0.93f, "Simulation: Thermal Drift Active", new Dictionary<string, float>());
    }

    private string GetRiskClass() => (_data?.Confidence * 100) > 70 ? "text-danger" : "text-success";

    private async Task Poll() {
        while (await _timer.WaitForNextTickAsync()) {
            await Fetch();
            await InvokeAsync(StateHasChanged);
        }
    }
    public void Dispose() => _timer.Dispose();
}

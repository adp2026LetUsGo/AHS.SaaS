@using AHS.Common.Models
@inject Services.GatewayClient Gateway
@implements IDisposable

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-start">
        <h3 style="color: var(--accent-blue);">XAI Risk Analysis</h3>
        <button class="btn btn-sm btn-outline-info" @onclick="() => _showModelScience = true">Model DNA</button>
    </div>

    <div class="mt-3">
        <label class="small opacity-75">RISK SENSITIVITY THRESHOLD: @(_sensitivity)%</label>
        <input type="range" class="form-range" min="50" max="95" @bind="_sensitivity" @bind:event="oninput" />
    </div>

    @if (_data != null)
    {
        <div class="mt-4 text-center">
            <h2 class="@GetRiskClass()">@(_data.Confidence.ToString("P0")) RISK</h2>
            <div class="risk-bar @GetRiskClass()" style="width: 100%"></div>
            
            <div class="glass-card bg-dark mt-4 mb-3" style="padding: 1rem;">
                <small class="text-warning">ROOT CAUSE</small>
                <p class="mb-0"><strong>@_data.RootCause</strong></p>
            </div>

            <div class="text-start">
                <small class="opacity-50">TOP CONTRIBUTING FACTORS:</small>
                <div class="mt-2">
                    @foreach(var factor in _data.TopFactors) {
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="small">🔹 @factor.Key</span>
                            <span class="badge bg-dark border border-secondary small">@(factor.Value.ToString("P0"))</span>
                        </div>
                        <div class="progress bg-dark" style="height: 4px;">
                            <div class="progress-bar bg-info" role="progressbar" style="width: @(factor.Value * 100)%"></div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="spinner-border text-info" role="status"></div>
            <p class="mt-2 small text-secondary">Synchronizing XAI Engine...</p>
        </div>
    }
</div>

@if (_showModelScience) {
    <div class="modal d-block" style="background: rgba(0,0,0,0.8); backdrop-filter: blur(8px);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content modal-glass p-4 shadow-lg">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Explainable DNA (XAI)</h4>
                    <span class="badge bg-info text-dark">v1.0.3-RELEASE</span>
                </div>
                <hr class="border-secondary"/>
                <div class="row text-center mb-4">
                    <div class="col-4">
                        <small class="text-secondary">Recall</small><br/>
                        <strong class="h4">@((_data?.Recall ?? 0.95f).ToString("P0"))</strong>
                    </div>
                    <div class="col-4">
                        <small class="text-secondary">Precision</small><br/>
                        <strong class="h4">@((_data?.Precision ?? 0.92f).ToString("P0"))</strong>
                    </div>
                    <div class="col-4">
                        <small class="text-secondary">F1 Score</small><br/>
                        <strong class="h4">@((_data?.F1Score ?? 0.93f).ToString("P0"))</strong>
                    </div>
                </div>
                <div class="bg-dark p-3 rounded mb-4">
                    <p class="small mb-1"><strong>Algorithm:</strong> FastTree (Gradient Boosting)</p>
                    <p class="small mb-1"><strong>Balancing:</strong> SMOTE Oversampling</p>
                    <p class="small mb-0"><strong>Matrix:</strong> Cost-Sensitive (Zero-Tolerance)</p>
                </div>
                <button class="btn btn-primary w-100" @onclick="() => _showModelScience = false">Close Analysis</button>
            </div>
        </div>
    </div>
}

@code {
    private AHS.Common.Models.PredictionResponse? _data;
    private int _sensitivity = 75;
    private bool _showModelScience = false;
    private PeriodicTimer _timer = new(TimeSpan.FromSeconds(3));

    protected override void OnInitialized() => _ = PollAsync();

    private string GetRiskClass() {
        var val = _data?.Confidence * 100;
        if (val < 30) return "risk-low";
        if (val < _sensitivity) return "risk-med";
        return "risk-high";
    }

    private async Task PollAsync() {
        while (await _timer.WaitForNextTickAsync()) {
            _data = await Gateway.GetPharmaRiskAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose() => _timer.Dispose();
}

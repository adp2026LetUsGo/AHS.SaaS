@page "/"
@using AHS.Common
@inject HttpClient Http

<PageTitle>Bento UI - Insulin Traceability</PageTitle>

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold accent-text">AHS.Web.BentoUI</h1>
        <p class="lead">Intelligent GxP Traceability & Risk Prediction</p>
    </div>

    <div class="bento-grid">
        <!-- Prediction Card -->
        <div class="bento-card" style="grid-column: span 2;">
            <h3 class="accent-text mb-4">Insulin Excursion Risk</h3>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Route ID</label>
                    <input type="text" class="form-control bg-dark text-white border-secondary" @bind="request.RouteId" placeholder="RT-1001" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Carrier</label>
                    <input type="text" class="form-control bg-dark text-white border-secondary" @bind="request.Carrier" placeholder="FedEx ColdChain" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Avg Temp (°C)</label>
                    <input type="number" class="form-control bg-dark text-white border-secondary" @bind="request.AvgTemp" step="0.1" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Transit Time (Hr)</label>
                    <input type="number" class="form-control bg-dark text-white border-secondary" @bind="request.TransitTime" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Packaging</label>
                    <select class="form-select bg-dark text-white border-secondary" @bind="request.Packaging">
                        <option value="VIP-Passive">VIP-Passive</option>
                        <option value="Active-PlugIn">Active-PlugIn</option>
                    </select>
                </div>
                <div class="col-12 mt-4">
                    <button class="btn btn-primary w-100 py-3" @onclick="PredictRisk" disabled="@isProcessing">
                        @if (isProcessing) {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Analyzing Core Inference...</span>
                        } else {
                            <span>Run GxP Inference</span>
                        }
                    </button>
                </div>
            </div>
        </div>

        <!-- Result Card -->
        @if (response != null) {
            <div class="bento-card">
                <h3 class="accent-text mb-3">Analysis Result</h3>
                <div class="d-flex align-items-center mb-3">
                    <div class="fs-1 me-3">@(response.IsHighRisk ? "⚠️" : "✅")</div>
                    <div>
                        <div class="fw-bold">Scoring: @response.Score.ToString("P2")</div>
                        <div class="badge @(response.IsHighRisk ? "bg-danger" : "bg-success")">@response.Status</div>
                    </div>
                </div>
                <p class="small text-secondary">
                    Inference powered by ML.NET & Native AOT.
                    Compliance SHA256 Hash generated and audited.
                </p>
            </div>
        }

        <!-- Stats Card -->
        <div class="bento-card">
            <h3 class="accent-text mb-3">System Health</h3>
            <ul class="list-unstyled">
                <li class="mb-2">🟢 Gateway API: Connected</li>
                <li class="mb-2">🟢 AOT Runtime: Optimized</li>
                <li class="mb-2">🟢 Firebase: Authenticated</li>
            </ul>
        </div>
    </div>
</div>

@code {
    private PredictRiskRequest request = new("RT-Default", "Global-Logistics", 24, 4.5, "VIP-Passive", false);
    private PredictRiskResponse? response;
    private bool isProcessing = false;

    private async Task PredictRisk() {
        isProcessing = true;
        try {
            var result = await Http.PostAsJsonAsync("http://localhost:5000/api/pharma/traceability/predict-risk", request);
            if (result.IsSuccessStatusCode) {
                response = await result.Content.ReadFromJsonAsync<PredictRiskResponse>();
            }
        } catch (Exception ex) {
            Console.WriteLine($"Error: {ex.Message}");
        } finally {
            isProcessing = false;
        }
    }
}

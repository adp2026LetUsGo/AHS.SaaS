
@using AHS.Common.Models

<div class="audit-ledger">

    
<div class="ledger-header">

        <span class="ledger-title">
GxP AUDIT LEDGER</span>
        <span class="ledger-count">
@Events.Count EVENTS</span>
    
</div>

    
<div class="ledger-timeline">

        
@if (Events.Count == 0)        {
            
<div class="ledger-empty">

No audit events recorded.
</div>

        
}        else        {
            
@foreach (var ev in Events.OrderByDescending(e =>
 e.Timestamp))            {
                
<div class="ledger-entry severity-@ev.Severity.ToString().ToLower()">

                    
<div class="entry-indicator">


</div>

                    
<div class="entry-body">

                        
<div class="entry-meta">

                            <span class="entry-time">
@ev.Timestamp.ToString("HH:mm:ss")</span>
                            <span class="entry-severity-badge">
@ev.Severity</span>
                        
</div>

                        
<div class="entry-name">

@ev.EventName
</div>

                        
<div class="entry-action">

→ @ev.ActionTaken
</div>

                        
<div class="entry-sig">

&#128274;
 @ev.DigitalSignature[..Math.Min(16, ev.DigitalSignature.Length)]...
</div>

                    
</div>

                
</div>

            
}        
}    
</div>


</div>

<style>
    .audit-ledger {
 height: 100%;
 display: flex;
 flex-direction: column;
 background: rgba(2,6,23,0.5);
 border-radius: 16px;
 border: 1px solid rgba(255,255,255,0.07);
 overflow: hidden;
 
}    .ledger-header {
 display: flex;
 justify-content: space-between;
 align-items: center;
 padding: 16px 20px;
 border-bottom: 1px solid rgba(255,255,255,0.07);
 background: rgba(255,255,255,0.02);
 
}    .ledger-title {
 font-size: 0.65rem;
 letter-spacing: 3px;
 font-weight: 800;
 color: #94a3b8;
 
}    .ledger-count {
 font-family: 'JetBrains Mono', monospace;
 font-size: 0.7rem;
 color: #38bdf8;
 
}    .ledger-timeline {
 flex: 1;
 overflow-y: auto;
 padding: 12px;
 display: flex;
 flex-direction: column;
 gap: 10px;
 
}    .ledger-timeline::-webkit-scrollbar {
 width: 4px;
 
}    .ledger-timeline::-webkit-scrollbar-thumb {
 background: rgba(255,255,255,0.1);
 border-radius: 2px;
 
}    .ledger-entry {
 display: flex;
 gap: 12px;
 padding: 12px;
 border-radius: 10px;
 background: rgba(255,255,255,0.02);
 border: 1px solid rgba(255,255,255,0.04);
 transition: background 0.2s;
 
}    .ledger-entry:hover {
 background: rgba(255,255,255,0.05);
 
}    .entry-indicator {
 width: 4px;
 border-radius: 2px;
 flex-shrink: 0;
 
}    .severity-info .entry-indicator {
 background: #38bdf8;
 
}    .severity-warning .entry-indicator {
 background: #f59e0b;
 
}    .severity-critical .entry-indicator {
 background: #ef4444;
 box-shadow: 0 0 8px rgba(239,68,68,0.4);
 
}    .entry-body {
 flex: 1;
 min-width: 0;
 
}    .entry-meta {
 display: flex;
 justify-content: space-between;
 margin-bottom: 4px;
 
}    .entry-time {
 font-family: 'JetBrains Mono', monospace;
 font-size: 0.65rem;
 color: #64748b;
 
}    .entry-severity-badge {
 font-size: 0.6rem;
 font-weight: 700;
 letter-spacing: 1px;
 padding: 2px 6px;
 border-radius: 4px;
 
}    .severity-info .entry-severity-badge {
 background: rgba(56,189,248,0.15);
 color: #38bdf8;
 
}    .severity-warning .entry-severity-badge {
 background: rgba(245,158,11,0.15);
 color: #f59e0b;
 
}    .severity-critical .entry-severity-badge {
 background: rgba(239,68,68,0.15);
 color: #ef4444;
 
}    .entry-name {
 font-size: 0.8rem;
 font-weight: 700;
 color: #f1f5f9;
 margin-bottom: 2px;
 white-space: nowrap;
 overflow: hidden;
 text-overflow: ellipsis;
 
}    .entry-action {
 font-size: 0.7rem;
 color: #94a3b8;
 margin-bottom: 4px;
 white-space: nowrap;
 overflow: hidden;
 text-overflow: ellipsis;
 
}    .entry-sig {
 font-family: 'JetBrains Mono', monospace;
 font-size: 0.6rem;
 color: #475569;
 
}    .ledger-empty {
 color: #475569;
 text-align: center;
 padding: 40px 0;
 font-size: 0.8rem;
 
}</style>


@code {

    
[Parameter] public List<AuditEvent>
 Events {
 get;
 set;
 
} = new();

}

